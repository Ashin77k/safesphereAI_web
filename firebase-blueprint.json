{
  "entities": {
    "Emergency": {
      "title": "Emergency",
      "description": "An active emergency report",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user in emergency" },
        "userName": { "type": "string", "description": "The name of the user" },
        "location": { "type": "object", "properties": { "lat": { "type": "number" }, "lng": { "type": "number" } } },
        "status": { "type": "string", "enum": ["ACTIVE", "SAFE"], "description": "Current status of the emergency" },
        "timestamp": { "type": "string", "format": "date-time", "description": "Time of the report" },
        "description": { "type": "string", "description": "Details about the emergency" }
      },
      "required": ["userId", "location", "status", "timestamp"]
    },
    "MissingPerson": {
      "title": "Missing Person",
      "description": "A report of a missing person",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the missing person" },
        "lastSeenLocation": { "type": "object", "properties": { "lat": { "type": "number" }, "lng": { "type": "number" } } },
        "status": { "type": "string", "enum": ["MISSING", "FOUND"], "description": "Current status" },
        "timestamp": { "type": "string", "format": "date-time", "description": "Time reported" },
        "description": { "type": "string", "description": "Last known details" },
        "reportedBy": { "type": "string", "description": "User ID who reported" }
      },
      "required": ["name", "lastSeenLocation", "status", "timestamp"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System alerts and notifications",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["EMERGENCY", "MISSING", "STATUS_UPDATE"] },
        "message": { "type": "string" },
        "severity": { "type": "string", "enum": ["HIGH", "MEDIUM", "LOW"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "relatedId": { "type": "string", "description": "ID of the emergency or missing person" }
      },
      "required": ["type", "message", "severity", "timestamp"]
    },
    "User": {
      "title": "User",
      "description": "Application user profile",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["ADMIN", "USER"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "role"]
    },
    "LocationHistory": {
      "title": "Location History",
      "description": "Periodic location updates for a specific emergency or missing person",
      "type": "object",
      "properties": {
        "parentId": { "type": "string", "description": "ID of the emergency or missing person" },
        "location": { "type": "object", "properties": { "lat": { "type": "number" }, "lng": { "type": "number" } } },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["parentId", "location", "timestamp"]
    }
  },
  "firestore": {
    "/emergencies": { "schema": "Emergency", "description": "Active and past emergency reports" },
    "/missingPersons": { "schema": "MissingPerson", "description": "Missing person reports" },
    "/notifications": { "schema": "Notification", "description": "System-wide notifications" },
    "/users": { "schema": "User", "description": "User profiles and roles" },
    "/locationHistory": { "schema": "LocationHistory", "description": "Tracking history for active cases" }
  }
}
